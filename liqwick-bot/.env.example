# LiqWick Bot — Regime Liq Wick strategy (Binance Futures)

DRY_RUN=true
DB_PATH=./data/liqwick.db
DASHBOARD_PORT=3850
DASHBOARD_HOST=127.0.0.1

# Binance Futures
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

SYMBOL_WHITELIST=BTCUSDT,ETHUSDT,SOLUSDT

# Regime (BTC global gate)
REGIME_SYMBOL=BTCUSDT
REGIME_TIMEFRAME=4h
REGIME_POLL_MS=900000
REGIME_EMA_PERIOD=200
REGIME_EMA_SLOPE_BARS=5

# Entry + confluence
ENTRY_MODE=reversal_tick
ENTER_THRESHOLD=60
ATR_PERIOD=14
SWEEP_ATR_K=0.25
REVERSAL_ATR_K=0.3
SL_ATR_K=0.5
SL_MIN_ATR=0.3
SL_MAX_ATR=3.0
TP1_R=1.0
TP2_R=2.0
TP1_CLOSE_PCT=50

# Liquidation + volume
LIQ_WINDOW_MS=10000
LIQ_BURST_MULT=3.0
VOL_SPIKE_MULT=2.0
SWEEP_TIMEOUT_MS=8000
WICK_VELOCITY_MS=10000

# Levels
LEVELS_REFRESH_MS=300000
FRACTAL_LOOKBACK=5

# Risk
DEFAULT_RISK_PCT=1
DEFAULT_BALANCE_USDT=1000
MAX_NOTIONAL_USDT=0
TRADE_COOLDOWN_MS=1800000
ABORT_COOLDOWN_MS=600000
DAILY_MAX_LOSS_USDT=0
MAX_CONCURRENT_POSITIONS=2
MAX_TRADES_PER_DAY=0

# Funding + basis positioning
FUNDING_EXTREME=0.0003
BASIS_EXTREME_BPS=4
POSITIONING_BIAS_MAX=5

# Optimization journal (forward DRY_RUN)
JOURNAL_ENABLED=true
NEAR_MISS_MIN_SCORE=45

# Backup retention (days, 0 = keep all backups)
JOURNAL_RETENTION_DAYS=30
