# Discord (Playwright — no bot token)
DISCORD_GUILD_ID=
DISCORD_TRADES_CHANNEL_ID=
DISCORD_ALERTS_CHANNEL_ID=
DISCORD_PROFILE_DIR=./data/discord-profile
WG_BOT_DISPLAY_NAME=WG Bot
WG_BOT_AUTHOR_ID=1023602697238237195
# Trader @mentions in #trades posts only (not personal #johnny/#eli channels).
# Spelling must match Discord @mention (no @ prefix here). Comma-separated.
FOLLOWED_TRADERS=Johnny,Woods,Eli,Michele,-Tareeq,Astekz

# Spike options
# 0 = listen until Ctrl+C (recommended for spike:unlock)
SPIKE_DURATION_MS=0
SPIKE_BACKFILL_LIMIT=20
# Max history depth for scroll backfill + REST replay (trades + alerts)
BACKFILL_MAX_AGE_DAYS=3
# Trade journal dashboard (separate terminal: npm run dashboard)
DASHBOARD_PORT=3847
# Keep Chromium minimized — no bringToFront on unlock/backfill (default: true)
DISCORD_KEEP_BACKGROUND=true

# DCA ladder
DCA_STEPS=3
DCA_WEIGHTS=25,35,40
ENTRY_STRATEGY=dca_ladder

# Execution
DRY_RUN=true
DB_PATH=./data/trades.db
DEFAULT_BALANCE_USDT=1000
DEFAULT_RISK_PCT=1
MAX_NOTIONAL_USDT=0

# Binance Futures (testnet default)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true
