# Discord (user session token — no bot token)
DISCORD_USER_TOKEN=
DISCORD_GUILD_ID=
DEGEN_CHANNEL_ID=
# Primary Discord user — buys with full spendable balance on DEGEN_WALLET_PRIVATE_KEY
DEGEN_WATCH_USER_ID=
# Shared wallet for all extra users below
DEGEN_EXTRA_WALLET_PRIVATE_KEY=
# Extra users: userId:buyFraction joined by | (shared extra wallet; 0.3 = 30% of spendable)
# DEGEN_EXTRA_WATCH=779205885683171340:0.3|189920943101968386:0.3|863385070261239828:0.3
DEGEN_EXTRA_WATCH=
# Profile dir used only by `npm run discord:login` to capture the token
DISCORD_PROFILE_DIR=./data/discord-profile

# Solana
SOLANA_RPC_URL=
DEGEN_WALLET_PRIVATE_KEY=
# Your personal wallet (Phantom etc.) — tokens are sent here after each buy
DEGEN_DEST_WALLET=
# Keep this much SOL untouched for fees/rent
DEGEN_GAS_RESERVE_SOL=0.02
# 1500 bps = 15% slippage (degen launches move fast)
DEGEN_SLIPPAGE_BPS=1500
# Optional Jupiter API key (higher rate limits)
JUPITER_API_KEY=

# Safety
DRY_RUN=true
# Skip buy if spendable balance is below this
DEGEN_MIN_BUY_SOL=0.01
# Extra priority fee (lamports) added to the swap tx
DEGEN_PRIORITY_FEE_LAMPORTS=200000

# Journal
DB_PATH=./data/degen.db

# Telegram alerts (required)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Balance change Telegram alerts (poll interval ms, default 30s)
DEGEN_BALANCE_POLL_MS=30000
